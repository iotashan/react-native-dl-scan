{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["dlscan"],
  "ios": {
    "iosModuleName": "DLScan"
  },
  "android": {
    "androidNamespace": ["dlscan"],
    "androidCxxLibName": "DLScan"
  },
  "autolinking": {
    "DLScan": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridDLScanIOS"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridDLScanAndroid"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
